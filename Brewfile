# Brewfile — build dependencies for vehicle-sim
# Run 'make install-deps' or 'brew bundle' to install everything listed here.

# Native C++ build
brew "imagemagick"
brew "cmake"
brew "bison" # optional — only needed when building the C++ parser

# ESP32 firmware toolchain
brew "arduino-cli"

# USB serial driver for CP2102 (if your ESP32 board uses this chip)
cask "silicon-labs-vcp-driver"
